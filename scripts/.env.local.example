# Copy this file to scripts/.env.local and fill in your values.
# scripts/.env.local is gitignored — never commit it.

# Your DigitalOcean droplet's public IP
DROPLET_HOST=

# SSH username (DigitalOcean default is 'root')
DROPLET_USER=root

# SSH password — leave empty to use key-based auth (recommended for CI/CD).
# For password auth on Mac: brew install sshpass
DROPLET_PASS=

# Where the app is deployed on the server
DEPLOY_DIR=/opt/urlshortener

# Discord webhook URL for status notifications.
# Create one: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK=
