{
  "title": "Golden Signals",
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "title": "Traffic (Requests per second)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total[1m])) by (status)",
          "expr": "sum(rate(flask_http_request_duration_seconds_count[5m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    },
    {
      "title": "Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le))",
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 Latency (Seconds)"
        }
      ]
    },
    {
      "title": "Errors (5xx Rate %)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "(sum(rate(flask_http_request_total{status=~\"5..\"}[1m])) / sum(rate(flask_http_request_total[1m]))) * 100",
          "expr": "(sum(rate(flask_http_request_duration_seconds_count{status=~\"5..\"}[5m])) / sum(rate(flask_http_request_duration_seconds_count[5m]))) * 100",
          "legendFormat": "Error Rate %"
        }
      ]
    },
    {
      "title": "Saturation (App Memory)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"flask-app\"}",
          "expr": "sum(process_resident_memory_bytes{job=\"flask-app\"})",
          "legendFormat": "App RSS Memory (Bytes)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "bytes"
        }
      }
    }
  ]
}